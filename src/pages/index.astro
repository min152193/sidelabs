---
import { ADSENSE_CONFIG } from '../config/adsenseConfig.js';
---
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SideLabs</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" type="image/png" sizes="32x32" href="/ico/fav_32.png?v=1">
    <link rel="apple-touch-icon" sizes="180x180" href="/ico/fav_180.png?v=1">
    <link rel="icon" type="image/png" sizes="192x192" href="/ico/fav_192.png?v=1">
    <style>
        /* Multi-page scrolling overrides */
        body {
            display: block !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            min-height: 100vh;
            background-attachment: fixed !important;
        }
        
        .controls-container {
            position: fixed !important;
        }

        .landing-section {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100dvh;
            width: 100%;
            position: relative;
            box-sizing: border-box;
        }

        /* Mechanic ①: Bouncing Chevron Indicator */
        .chevron-indicator {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 100;
            cursor: pointer;
            transition: opacity 0.4s ease, visibility 0.4s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            color: var(--text-main);
            opacity: 0.8;
            pointer-events: auto;
        }
        
        .chevron-indicator.fade-out {
            opacity: 0;
            pointer-events: none;
        }
        
        .chevron-arrow {
            font-size: 1.8rem;
            line-height: 1;
            font-weight: bold;
            animation: bobbing 1.5s infinite ease-in-out;
        }
        
        .chevron-text {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 0.25rem;
            opacity: 0.7;
        }
        
        @keyframes bobbing {
            0%, 100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(8px);
            }
        }

        /* Scroll Space to trigger cinematic redirect transition */
        .scroll-spacer {
            height: 60vh;
            width: 100%;
            pointer-events: none;
        }

        #redirect-sentinel {
            height: 10px;
            width: 100%;
            pointer-events: none;
        }

        /* Mechanic ③: Immersive Fade-to-Black Overlay */
        #transition-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 9999;
            opacity: 0;
            pointer-events: none;
            background: #000000;
            transition: opacity 1.0s cubic-bezier(0.25, 1, 0.5, 1);
        }
        
        #transition-overlay.is-active {
            opacity: 1;
            pointer-events: auto;
        }
    </style>
</head>
<body class="dark-mode">

    <div class="controls-container">
        <button class="toggle-btn" id="theme-toggle">LIGHT MODE</button>
        <button class="toggle-btn" id="pause-toggle">PAUSE</button>
    </div>

    <!-- Main portfolio landing page -->
    <section class="landing-section">
        <div class="main-wrapper">
            <div class="card-container" id="interactive-card">
                <div class="card" id="card-element">
                    
                    <div class="card-face front-face">
                        <div class="card-bg"></div>
                        <div class="border-glow"></div>
                        <div class="glint"></div>
                        <div class="card-content">
                            <h1 class="logo">SideLabs</h1>
                            <div class="contact-section">
                                <div class="label">Contact</div>
                                <a class="email-btn" href="mailto:contact@sidelabs.net">contact@sidelabs.net</a>
                            </div>
                        </div>
                    </div>

                    <div class="card-face back-face">
                        <div class="card-bg"></div>
                        <div class="border-glow"></div>
                        <div class="glint"></div>
                        <div class="solid-overlay"></div>
                        <div class="card-content center-content">
                            <form class="login-grid" id="login-form">
                                <div class="login-title">LOGIN</div>
                                <div class="login-fields">
                                    <input type="email" name="email" class="login-input" placeholder="Email" required>
                                    <input type="password" name="password" class="login-input" placeholder="Password" required>
                                    <button type="submit" class="submit-btn">SIGN IN</button>
                                </div>
                            </form>
                        </div>
                    </div>

                </div>
            </div>

            <div class="action-container">
                <button class="spin-btn" id="spin-trigger">LOGIN</button>
            </div>
        </div>
    </section>

    <!-- Bouncing Chevron Indicator -->
    <div class="chevron-indicator" id="scroll-chevron">
        <span class="chevron-text">Scroll Down</span>
        <span class="chevron-arrow">∨</span>
    </div>

    <!-- Scroll Spacer and Sentinel for Redirection -->
    <div class="scroll-spacer"></div>
    <div id="redirect-sentinel"></div>

    <!-- Fullscreen Blackout Transition Overlay -->
    <div id="transition-overlay"></div>

    <script src="/app.js" is:inline></script>
    
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const chevron = document.getElementById('scroll-chevron');
            const sentinel = document.getElementById('redirect-sentinel');
            const overlay = document.getElementById('transition-overlay');

            // Mechanic ①: Scroll Fade-out for Chevron
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) {
                    chevron.classList.add('fade-out');
                } else {
                    chevron.classList.remove('fade-out');
                }
            });

            // Mechanic ③: Freeze scroll, blackout and redirect
            if (sentinel && overlay) {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            // 1. Freeze standard scrolling interface
                            document.body.style.overflow = 'hidden';
                            document.documentElement.style.overflow = 'hidden';
                            
                            // 2. Play fade-to-black animation
                            overlay.classList.add('is-active');
                            
                            // 3. Redirection after blackout animation hits full opacity
                            setTimeout(() => {
                                window.location.href = '/blog';
                            }, 1000);
                        }
                    });
                }, {
                    threshold: 0.1
                });
                observer.observe(sentinel);
            }
        });
    </script>
</body>
</html>
