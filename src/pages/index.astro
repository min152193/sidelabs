---
import { ADSENSE_CONFIG } from '../config/adsenseConfig.js';
---
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SideLabs</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" type="image/png" sizes="32x32" href="/ico/fav_32.png?v=1">
    <link rel="apple-touch-icon" sizes="180x180" href="/ico/fav_180.png?v=1">
    <link rel="icon" type="image/png" sizes="192x192" href="/ico/fav_192.png?v=1">
    <style>
        /* Multi-page scrolling overrides */
        body {
            display: block !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            min-height: 100vh;
            background-attachment: fixed !important;
        }
        
        .controls-container {
            position: fixed !important;
        }

        .landing-section {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100dvh;
            width: 100%;
            position: relative;
            box-sizing: border-box;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translate(-50%, 0); }
            40% { transform: translate(-50%, -10px); }
            60% { transform: translate(-50%, -5px); }
        }

        /* Scroll Space to trigger cinematic redirect transition */
        .scroll-spacer {
            height: 60vh;
            width: 100%;
            pointer-events: none;
        }

        #redirect-sentinel {
            height: 10px;
            width: 100%;
            pointer-events: none;
        }

    </style>
</head>
<body class="dark-mode">
    <div class="controls-container">
        <button class="toggle-btn" id="theme-toggle">LIGHT MODE</button>
        <button class="toggle-btn" id="pause-toggle">PAUSE</button>
    </div>

    <!-- Main portfolio landing page -->
    <section class="landing-section">
        <div class="main-wrapper">
            <div class="card-container" id="interactive-card">
                <div class="card" id="card-element">
                    
                    <div class="card-face front-face">
                        <div class="card-bg"></div>
                        <div class="border-glow"></div>
                        <div class="glint"></div>
                        <div class="card-content">
                            <h1 class="logo">SideLabs</h1>
                            <div class="contact-section">
                                <div class="label">Contact</div>
                                <a class="email-btn" href="mailto:contact@sidelabs.net">contact@sidelabs.net</a>
                            </div>
                        </div>
                    </div>

                    <div class="card-face back-face">
                        <div class="card-bg"></div>
                        <div class="border-glow"></div>
                        <div class="glint"></div>
                        <div class="solid-overlay"></div>
                        <div class="card-content center-content">
                            <form class="login-grid" id="login-form">
                                <div class="login-title">LOGIN</div>
                                <div class="login-fields">
                                    <input type="email" name="email" class="login-input" placeholder="Email" required>
                                    <input type="password" name="password" class="login-input" placeholder="Password" required>
                                    <button type="submit" class="submit-btn">SIGN IN</button>
                                </div>
                            </form>
                        </div>
                    </div>

                </div>
            </div>

            <div class="action-container">
                <button class="spin-btn" id="spin-trigger">LOGIN</button>
            </div>
        </div>
    </section>


    <!-- Scroll Spacer and Sentinel for Redirection -->
    <div class="scroll-spacer"></div>
    <div id="redirect-sentinel"></div>


    <script src="/app.js" is:inline></script>
    
    <script is:inline>
      (function() {
        window.addEventListener('DOMContentLoaded', function() {
          var indicator = document.getElementById('scroll-indicator');
          
          // Standalone scroll controller for the text/arrow indicator
          window.addEventListener('scroll', function() {
            if (indicator) {
              if (window.scrollY > 20) {
                indicator.style.opacity = '0';
                indicator.style.visibility = 'hidden';
              } else {
                indicator.style.opacity = '1';
                indicator.style.visibility = 'visible';
              }
            }
          }, { passive: true });

          // Insurance click-to-redirect backup
          if (indicator) {
            indicator.style.pointerEvents = 'auto';
            indicator.style.cursor = 'pointer';
            indicator.addEventListener('click', function() {
              window.location.href = '/blog';
            });
          }

          // Standalone sentinel tracking for bottom-out navigation
          var sentinel = document.getElementById('redirect-sentinel');
          if (sentinel) {
            var observer = new IntersectionObserver(function(entries) {
              if (entries[0].isIntersecting) {
                document.body.style.opacity = '0';
                document.body.style.transition = 'opacity 0.5s ease';
                setTimeout(function() {
                  window.location.href = '/blog';
                }, 500);
              }
            }, { threshold: 0.05 });
            observer.observe(sentinel);
          }
        });
      })();
    </script>

<div id="scroll-indicator" style="position: fixed !important; bottom: 40px; left: 50%; transform: translateX(-50%); display: block !important; text-align: center !important; z-index: 2147483647 !important; color: #94a3b8; font-family: 'Poppins', sans-serif; font-size: 0.75rem; letter-spacing: 0.2em; animation: bounce 2s infinite; pointer-events: none; mix-blend-mode: difference !important; visibility: visible !important; opacity: 1 !important;">
  <span style="font-weight: 600; display: block;">SCROLL DOWN</span>
  <span style="font-size: 1.8rem; margin-top: 5px; font-weight: bold; line-height: 1; display: block;">↓</span>
</div>

<style is:global>
  html, body {
    overflow-y: auto !important;
    overflow-x: hidden !important;
    height: auto !important;
    min-height: 100vh !important;
    position: relative !important;
    touch-action: pan-y !important;
  }
  /* Liberate the target content wrappers from layout trapping */
  .main-wrapper, .landing-section {
    position: relative !important;
    overflow: visible !important;
    height: auto !important;
    min-height: 100vh !important;
  }
</style>
</body>
</html>
