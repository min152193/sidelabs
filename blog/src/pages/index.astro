---
// Virtual Scroll Restored index.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SideLabs</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" type="image/png" sizes="32x32" href="/ico/fav_32.png?v=1">
    
    <style>
        /* Bouncing Arrow Animation */
        @keyframes bounceTarget {
            0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
            40% { transform: translateX(-50%) translateY(-10px); }
            60% { transform: translateX(-50%) translateY(-5px); }
        }
        #virtual-scroll-indicator {
            position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%);
            display: flex; flex-direction: column; align-items: center;
            z-index: 2147483647; color: #94a3b8; font-family: 'Poppins', sans-serif;
            font-size: 0.75rem; letter-spacing: 0.2em; animation: bounceTarget 2s infinite;
            pointer-events: auto; cursor: pointer; transition: opacity 0.5s ease;
        }
    </style>
</head>
<body class="dark-mode" style="overflow: hidden !important;">

    <div class="controls-container">
        <button class="toggle-btn" id="theme-toggle">LIGHT MODE</button>
        <button class="toggle-btn" id="pause-toggle">PAUSE</button>
    </div>

    <div class="main-wrapper">
        <div class="card-container" id="interactive-card">
            <div class="card" id="card-element">
                <div class="card-face front-face">
                    <div class="card-bg"></div>
                    <div class="border-glow"></div>
                    <div class="glint"></div>
                    <div class="card-content">
                        <h1 class="logo">SideLabs</h1>
                        <div class="contact-section">
                            <div class="label">Contact</div>
                            <a class="email-btn" href="mailto:contact@sidelabs.net">contact@sidelabs.net</a>
                        </div>
                    </div>
                </div>
                <div class="card-face back-face">
                    <div class="card-bg"></div>
                    <div class="border-glow"></div>
                    <div class="glint"></div>
                    <div class="solid-overlay"></div>
                    <div class="card-content center-content">
                        <form class="login-grid" id="login-form">
                            <div class="login-title">LOGIN</div>
                            <div class="login-fields">
                                <input type="email" name="email" class="login-input" placeholder="Email" required>
                                <input type="password" name="password" class="login-input" placeholder="Password" required>
                                <button type="submit" class="submit-btn">SIGN IN</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="action-container">
            <button class="spin-btn" id="spin-trigger">LOGIN</button>
        </div>
    </div>

    <div id="virtual-scroll-indicator">
        <span style="font-weight: 600;">SCROLL DOWN</span>
        <span style="font-size: 1.8rem; margin-top: 5px; font-weight: bold; line-height: 1;">↓</span>
    </div>

    <div class="global-footer">© SideLabs. All rights reserved.</div>

    <script is:inline src="/app.js"></script>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            var isRedirecting = false;
            var indicator = document.getElementById('virtual-scroll-indicator');

            function triggerRedirect() {
                if (isRedirecting) return;
                isRedirecting = true;
                if (indicator) indicator.style.opacity = '0';
                
                // Fade entire body
                document.body.style.transition = 'opacity 0.6s ease';
                document.body.style.opacity = '0';
                
                setTimeout(function() {
                    window.location.href = '/blog';
                }, 600);
            }

            // Detect Desktop Mouse Wheel
            window.addEventListener('wheel', function(e) {
                if (e.deltaY > 30) triggerRedirect(); // User scrolled downwards
            }, { passive: true });

            // Detect Mobile Touch Swipe
            var touchStartY = 0;
            window.addEventListener('touchstart', function(e) {
                touchStartY = e.touches[0].clientY;
            }, { passive: true });
            
            window.addEventListener('touchmove', function(e) {
                var touchEndY = e.touches[0].clientY;
                if (touchStartY - touchEndY > 40) triggerRedirect(); // User swiped upwards
            }, { passive: true });

            // Fallback Arrow Click
            if (indicator) indicator.addEventListener('click', triggerRedirect);
        });
    </script>
</body>
</html>